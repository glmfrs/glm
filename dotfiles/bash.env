### $HOME/.bash.env
umask 077
export PS1='[\u@\h \w]\\$ '
WHITE='\[\e[0m\]'
BLACK='\[\e[01;30m\]'
RED='\[\e[01;31m\]'
GREEN='\[\e[01;32m\]'
YELLOW='\[\e[01;33m\]'
BLUE='\[\e[01;34m\]'
PURPLE='\[\e[01;35m\]'
CYAN='\[\e[01;36m\]'
GREY='\[\e[01;37m\]'
# User Metal  PS1="$BLUE\u$YELLOW@$WHITE\h$YELLOW:$GREEN\w $YELLOW$ $WHITE"
# User VM     PS1="$BLUE\u$YELLOW@$PURPLE\h$YELLOW:$GREEN\w $YELLOW$ $WHITE"
# ROOT Metal  PS1="$RED\u$YELLOW@$WHITE\h$YELLOW:$GREEN\w $YELLOW# $WHITE"
# ROOT VM     PS1="$RED\u$YELLOW@$PURPLE\h$YELLOW:$GREEN\w $YELLOW# $WHITE"
export HISTSIZE=999999
export HISTFILESIZE=999999
export HISTTIMEFORMAT="[%F %T] "
export EDITOR='vim'
export VISUAL='$EDITOR'
export PAGER='less'
export LESS_TERMCAP_mb=$'\e[1;31m'
export LESS_TERMCAP_md=$'\e[1;33m'
export LESS_TERMCAP_so=$'\e[01;44;37m'
export LESS_TERMCAP_us=$'\e[01;37m'
export LESS_TERMCAP_me=$'\e[0m'
export LESS_TERMCAP_se=$'\e[0m'
export LESS_TERMCAP_ue=$'\e[0m'
export GROFF_NO_SGR=1